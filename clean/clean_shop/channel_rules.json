        {"含": "42节", "IP": "青越", "类目": "课", "订单区分": "初中订单"}
    ],

    "_输出字段": {
        "订单": [
            {"字段": "渠道",     "来源类型": "自动",   "说明": "根据渠道名覆盖规则自动填入，如'百家号'"},
            {"字段": "店铺",     "来源类型": "自动",   "说明": "从文件名提取+店铺名覆盖，如'百家号_强风课堂'"},
            {"字段": "年份",     "来源类型": "计算",   "规则": "取下单月份的前4位，如202601→2026"},
            {"字段": "下单月份", "来源类型": "计算",   "规则": "见各渠道的月份提取配置，格式yyyymm"},
            {"字段": "IP",       "来源类型": "映射库", "说明": "用商品名+金额去商品映射库匹配"},
            {"字段": "类目",     "来源类型": "映射库", "说明": "用商品名+金额去商品映射库匹配"},
            {"字段": "订单区分", "来源类型": "映射库", "说明": "用商品名+金额去商品映射库匹配"},
            {"字段": "商品数量", "来源类型": "数据源", "聚合": "求和", "说明": "原始表里的数量字段，按分组维度求和"},
            {"字段": "订单数量", "来源类型": "数据源", "聚合": "计数", "计数字段": "订单编号", "说明": "统计订单编号的个数"},
            {"字段": "订单收入", "来源类型": "数据源", "聚合": "求和", "说明": "原始表里的金额字段，按分组维度求和"}
        ],
        "售后": [
            {"字段": "渠道",     "来源类型": "自动",   "说明": "同订单"},
            {"字段": "店铺",     "来源类型": "自动",   "说明": "同订单"},
            {"字段": "售后月份", "来源类型": "计算",   "规则": "见各渠道的月份提取配置，格式yyyymm"},
            {"字段": "下单月份", "来源类型": "计算",   "规则": "通过订单编号关联订单数据获取"},
            {"字段": "IP",       "来源类型": "映射库", "说明": "优先自身数据，缺失时通过订单编号从订单匹配"},
            {"字段": "类目",     "来源类型": "映射库", "说明": "同IP"},
            {"字段": "订单区分", "来源类型": "映射库", "说明": "同IP"},
            {"字段": "订单数量", "来源类型": "数据源", "聚合": "计数", "计数字段": "订单编号", "说明": "统计售后涉及的订单编号个数"},
            {"字段": "退商品金额","来源类型": "数据源", "聚合": "求和", "说明": "原始表里的退款金额字段，按分组维度求和"}
        ]
    },

    "百度": {
        "文件识别": {
            "订单": {"含": "百度", "不含": ["售后", "账单"]},
            "售后": {"含": ["百度", "售后"]}
        },
        "读取方式": {
            "订单": {"格式": "excel", "header行": 9},
            "售后": {"格式": "csv"}
        },
        "过滤规则": {
            "订单": {"剔除字段": "订单状态", "剔除值": ["订单取消"]},
            "售后": {"保留字段": "售后状态", "保留值含": ["退款成功"]}
        },
        "月份提取": {
            "订单": {"目标字段": "下单月份", "来源字段": "支付时间", "格式": "yyyymm"},
            "售后": {"目标字段": "售后月份", "来源字段": "申请时间", "格式": "yyyymm"}
        },
        "字段映射": {
            "订单": {
                "订单编号": "订单编号",
                "选购产品": "商品名",
                "数量": "商品数量",
                "实付金额": "订单收入",
                "订单状态": "订单状态",
                "支付时间": "支付时间"
            },
            "售后": {
                "订单编号": "订单编号",
                "售后编号": "售后编号",
                "商品名称": "商品名",
                "退款金额": "退商品金额",
                "售后状态": "售后状态",
                "申请时间": "申请时间"
            }
        },
        "映射库": {
            "sheet名": "百度",
            "引用键": ["选购产品", "实付金额"],
            "匹配键": ["商品名", "订单收入"],
            "获取字段": ["IP", "类目", "订单区分"]
        }
    },

